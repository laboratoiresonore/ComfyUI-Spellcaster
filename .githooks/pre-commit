#!/bin/bash
# internal-core/hooks/pre-commit — credential-leak guard
#
# Source-of-truth canonical hook for the Spellcaster / Spellcaster /
# the private downstream distribution / internal-tools lattice. Mirrors the regex used by
# Spellcaster's .claude/settings.json PreToolUse hook so that:
#   - Claude Code commits are blocked at PreToolUse time
#   - Plain `git commit` (terminal, IDE) is blocked at pre-commit time
#   - Both share the same regex; if you tighten one, tighten the other
#
# Pattern source: internal roadmap §F.6.2 Wk 1 Thu, §10.7.
# Vendoring: copied verbatim into <repo>/.git/hooks/pre-commit.
# Once internal-core ships (internal roadmap §C, Wk 5-19), this lives at
# internal-core/hooks/pre-commit and consumers symlink/install it.
#
# Override (use with care, audit afterwards):
#   SKIP_LEAK_CHECK=1 git commit ...
#
# Exit codes: 0 ok, 1 blocked.

set -e

PATTERN='192\.168\.86\.(31|23|77|219)|redacted|redacted|@gmail\.com|ghp_[A-Za-z0-9]'

files=$(git diff --cached --diff-filter=ACMR --name-only 2>/dev/null)
[ -z "$files" ] && exit 0

# grep only existing regular files; skip symlinks / submodules; skip the
# hook itself (its source contains the very pattern it scans for).
hits=$(printf '%s\n' "$files" | while IFS= read -r f; do
  [ -f "$f" ] || continue
  case "$f" in
    .githooks/pre-commit|.githooks/README.md) continue ;;
  esac
  grep -lInE "$PATTERN" -- "$f" 2>/dev/null || true
done)

if [ -n "$hits" ]; then
  echo >&2 ""
  echo >&2 "================================================================"
  echo >&2 "  pre-commit BLOCKED: personal data in staged files"
  echo >&2 "================================================================"
  echo >&2 "$hits" | sed 's/^/  /' >&2
  echo >&2 ""
  echo >&2 "  Pattern: $PATTERN"
  echo >&2 "  Sanitize before committing. To override (audit later):"
  echo >&2 "    SKIP_LEAK_CHECK=1 git commit ..."
  echo >&2 "================================================================"
  if [ "${SKIP_LEAK_CHECK:-0}" != "1" ]; then
    exit 1
  fi
  echo >&2 "  SKIP_LEAK_CHECK=1 set; permitting commit anyway."
fi

exit 0
